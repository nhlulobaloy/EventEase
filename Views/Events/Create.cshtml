@model EventEase.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<h1>Create Event</h1>

<form asp-action="Create" method="post">
    <div class="form-group mb-2">
        <label asp-for="EventName" class="form-label"></label>
        <input asp-for="EventName" class="form-control" />
        <span asp-validation-for="EventName" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="EventDate" class="form-label"></label>
        <input asp-for="EventDate" type="datetime-local" class="form-control" />
        <span asp-validation-for="EventDate" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="VenueId" class="form-label"></label>
        <select asp-for="VenueId" class="form-select" asp-items="@(ViewData["VenueId"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList)">
            <option value="">-- Select Venue --</option>
        </select>
        <span asp-validation-for="VenueId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-2">Create</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}