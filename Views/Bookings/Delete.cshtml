@model EventEase.Models.Booking

<h2>Delete Booking</h2>

<h4>Are you sure you want to delete this booking?</h4>

<div>
    <p><strong>Event:</strong> @Model.Event?.EventName</p>
    <p><strong>Venue:</strong> @Model.Venue?.VenueName</p>
    <p><strong>Booking Date:</strong> @Model.BookingDate.ToShortDateString()</p>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="BookingId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>