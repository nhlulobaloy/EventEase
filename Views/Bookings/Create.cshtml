@model EventEase.Models.Booking

@{
    ViewData["Title"] = "Create Booking";
}

<h1>Create Booking</h1>

<form asp-action="Create" method="post">
    <div class="form-group mb-2">
        <label asp-for="EventId" class="form-label"></label>
        <select asp-for="EventId" class="form-select" asp-items="@(ViewData["EventId"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList)">
            <option value="">-- Select Event --</option>
        </select>
        <span asp-validation-for="EventId" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="VenueId" class="form-label"></label>
        <select asp-for="VenueId" class="form-select" asp-items="@(ViewData["VenueId"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList)">
            <option value="">-- Select Venue --</option>
        </select>
        <span asp-validation-for="VenueId" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="BookingDate" class="form-label"></label>
        <input asp-for="BookingDate" type="datetime-local" class="form-control" />
        <span asp-validation-for="BookingDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-2">Create Booking</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}